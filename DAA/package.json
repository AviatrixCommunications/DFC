{
  "name": "aviatrix",
  "version": "1.0.0",
  "description": "Hybrid Block Editor-based WordPress theme for Aviatrix Communications projects",
  "main": "index.js",
  "scripts": {
    "build": "webpack --mode production && node build-block-css.js",
    "build:blocks": "node build-block-css.js",
    "watch": "concurrently \"webpack --watch --mode development\" \"node build-block-css.js --watch\"",
    "dev": "concurrently \"webpack --mode development --watch\" \"node build-block-css.js --watch\""
  },
  "keywords": [],
