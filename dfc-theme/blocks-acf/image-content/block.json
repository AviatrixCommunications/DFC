{
    "name": "image-content",
    "title": "Image + Content",
    "description": "Two-column image and content block",
    "category": "aviatrix-blocks",
    "icon": "align-pull-left",
    "keywords": [
        "image",
        "content",
        "media",
        "text"
    ],
    "styles": [
        { "name": "half-image-left",    "label": "½ Image Left",    "isDefault": true },
        { "name": "half-image-right",   "label": "½ Image Right" },
        { "name": "third-image-left",   "label": "⅓ Image Left" },
        { "name": "third-image-right",  "label": "⅓ Image Right" },
        { "name": "quarter-image-left", "label": "¼ Image Left" },
        { "name": "quarter-image-right","label": "¼ Image Right" }
    ],
    "style": "file:./style.css",
    "acf": {
        "mode": "preview",
        "renderTemplate": "image-content.php"
    },
    "supports": {
        "anchor": true,
        "jsx": true,
        "align": false,
        "color": {
            "text": false,
            "background": true
        },
        "spacing": false
    },
    "example": {
        "attributes": {
            "mode": "preview",
            "data": {
                "is_preview": true
            }
        }
    }
}
