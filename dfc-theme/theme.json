    "styles": {
        "spacing": {
            "padding": {
                "top": "0",
                "bottom": "0",
                "left": "24px",
                "right": "24px"
            },
            "blockGap": "clamp(16px, 2.5vw, 24px)"
        },
        "blocks": {
            "core/buttons": {
                "spacing": {
                    "blockGap": "2rem"
                }
            },
            "core/columns": {
                "spacing": {
                    "blockGap": "5rem"
                }
            },
            "core/paragraph": {
                "spacing": {
                    "margin": {
                        "top": "16px",
                        "bottom": "16px"
                    }
                }
            }
        },
        "elements": {
            "link": {
                "typography": {
                    "textDecoration": "none"
                }
            },
            "h2": {
                "css": "& { margin-top: clamp(32px, 4.5vw, 48px); margin-bottom: 24px; }"
            },
            "h3": {
                "css": "& { margin-top: 32px; margin-bottom: 24px; }"
            },
            "h4": {
                "css": "& { margin-top: 32px; margin-bottom: 16px; }"
            }
        }
